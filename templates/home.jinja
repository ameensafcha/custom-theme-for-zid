{% extends 'layout.jinja' %}

{% block content %}

{% set featured_products = [
  {"name": "Wireless Headphones", "slug": "wireless-headphones", "price": "299", "sale_price": "199", "images": [{"url": "https://picsum.photos/seed/prod1/400/400"}]},
  {"name": "Smart Watch", "slug": "smart-watch", "price": "599", "sale_price": null, "images": [{"url": "https://picsum.photos/seed/prod2/400/400"}]},
  {"name": "Running Shoes", "slug": "running-shoes", "price": "450", "sale_price": "380", "images": [{"url": "https://picsum.photos/seed/prod3/400/400"}]},
  {"name": "Leather Bag", "slug": "leather-bag", "price": "750", "sale_price": null, "images": [{"url": "https://picsum.photos/seed/prod4/400/400"}]},
  {"name": "Sunglasses", "slug": "sunglasses", "price": "199", "sale_price": "149", "images": [{"url": "https://picsum.photos/seed/prod5/400/400"}]},
  {"name": "Bluetooth Speaker", "slug": "bluetooth-speaker", "price": "350", "sale_price": null, "images": [{"url": "https://picsum.photos/seed/prod6/400/400"}]},
  {"name": "Laptop Stand", "slug": "laptop-stand", "price": "180", "sale_price": "120", "images": [{"url": "https://picsum.photos/seed/prod7/400/400"}]},
  {"name": "Wireless Mouse", "slug": "wireless-mouse", "price": "220", "sale_price": null, "images": [{"url": "https://picsum.photos/seed/prod8/400/400"}]}
] %}

<!-- ===== HERO BANNER ===== -->
<section class="relative bg-indigo-600 text-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 py-24 flex flex-col md:flex-row items-center gap-10">

    <!-- Left Text -->
    <div class="flex-1 text-center md:text-left">
      <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6">
        Shop the <span class="text-yellow-300">Best</span> Products Online
      </h1>
      <p class="text-lg md:text-xl text-indigo-100 mb-8">
        Discover amazing deals on top-quality items. Fast delivery, easy returns.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
        <a href="/products" class="bg-yellow-300 text-indigo-900 font-bold px-8 py-3 rounded-full hover:bg-yellow-400 transition text-center">
          Shop Now
        </a>
        <a href="/categories" class="border-2 border-white text-white font-bold px-8 py-3 rounded-full hover:bg-white hover:text-indigo-600 transition text-center">
          Browse Categories
        </a>
      </div>
    </div>

    <!-- Right Image -->
    <div class="flex-1 flex justify-center">
      <div class="w-72 h-72 md:w-96 md:h-96 bg-indigo-500 rounded-3xl flex items-center justify-center shadow-2xl">
        <svg class="w-40 h-40 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
      </div>
    </div>

  </div>

  <!-- Wave -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path fill="#ffffff" d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z"/>
    </svg>
  </div>
</section>

<!-- ===== TRUST BADGES ===== -->
<section class="bg-white py-10 border-b">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
    <div class="flex flex-col items-center gap-2">
      <span class="text-3xl">🚚</span>
      <p class="font-semibold text-gray-700">Free Shipping</p>
      <p class="text-xs text-gray-400">On orders over $50</p>
    </div>
    <div class="flex flex-col items-center gap-2">
      <span class="text-3xl">🔒</span>
      <p class="font-semibold text-gray-700">Secure Payment</p>
      <p class="text-xs text-gray-400">100% protected</p>
    </div>
    <div class="flex flex-col items-center gap-2">
      <span class="text-3xl">↩️</span>
      <p class="font-semibold text-gray-700">Easy Returns</p>
      <p class="text-xs text-gray-400">30-day return policy</p>
    </div>
    <div class="flex flex-col items-center gap-2">
      <span class="text-3xl">💬</span>
      <p class="font-semibold text-gray-700">24/7 Support</p>
      <p class="text-xs text-gray-400">Always here to help</p>
    </div>
  </div>
</section>

<!-- ===== FEATURED PRODUCTS ===== -->
<section class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4">

    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800">Featured Products</h2>
      <p class="text-gray-500 mt-3">Handpicked just for you</p>
      <div class="w-16 h-1 bg-indigo-600 mx-auto mt-4 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for product in featured_products %}
      <a href="/p/{{ product.slug }}" class="bg-white rounded-2xl shadow hover:shadow-lg transition overflow-hidden group">

        <div class="relative overflow-hidden bg-gray-100 h-52">
          {% if product.images %}
          <img src="{{ product.images[0].url }}" alt="{{ product.name }}"
            class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
          {% else %}
          <div class="w-full h-full flex items-center justify-center text-gray-300">
            <svg class="w-16 h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
          </div>
          {% endif %}

          {% if product.sale_price %}
          <span class="absolute top-2 left-2 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full">
            SALE
          </span>
          {% endif %}
        </div>

        <div class="p-4">
          <h3 class="text-sm font-semibold text-gray-800 truncate mb-1">{{ product.name }}</h3>
          <div class="flex items-center gap-2 mt-2">
            {% if product.sale_price %}
            <span class="text-indigo-600 font-bold">{{ product.sale_price }} SAR</span>
            <span class="text-gray-400 line-through text-xs">{{ product.price }} SAR</span>
            {% else %}
            <span class="text-indigo-600 font-bold">{{ product.price }} SAR</span>
            {% endif %}
          </div>
          <button onclick="addToCart('{{ product.slug }}', 1)" class="mt-3 w-full bg-indigo-600 text-white text-sm py-2 rounded-xl hover:bg-indigo-700 transition font-medium">
            Add to Cart
          </button>
        </div>

      </a>
      {% endfor %}
    </div>

    <div class="text-center mt-12">
      <a href="/products" class="inline-block bg-indigo-600 text-white font-bold px-10 py-3 rounded-full hover:bg-indigo-700 transition">
        View All Products
      </a>
    </div>

  </div>
</section>

{% endblock %}