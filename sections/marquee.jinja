<section class="w-full bg-black overflow-hidden py-3">
  <div class="marquee-track">
    {% for i in range(10) %}
      <span class="text-white text-sm font-medium mx-8">FREE SHIPPING ON ORDERS OVER 200 SAR</span>
      <span class="text-yellow-400 mx-4">✦</span>
    {% endfor %}
  </div>
</section>

<style>
  .marquee-track {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    animation: marquee-scroll 20s linear infinite;
  }
  @keyframes marquee-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>