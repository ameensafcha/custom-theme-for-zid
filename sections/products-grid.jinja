<section class="py-14 bg-white">
  <div class="px-4">

    <!-- Heading -->
    <div class="flex items-center justify-between mb-8 max-w-7xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900">Best Sellers</h2>
      <a href="/products" class="text-sm font-semibold text-gray-700 hover:underline">View all products</a>
    </div>

    <!-- Skeleton -->
    <div id="products-skeleton" class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {% for i in range(4) %}
      <div class="bg-white overflow-hidden animate-pulse border border-gray-100">
        <div class="bg-gray-200 h-80 md:h-[420px]"></div>
        <div class="p-5 space-y-3">
          <div class="h-3 bg-gray-200 rounded w-1/2"></div>
          <div class="h-4 bg-gray-200 rounded w-3/4"></div>
          <div class="h-3 bg-gray-200 rounded w-2/3"></div>
          <div class="h-10 bg-gray-200 rounded-xl mt-4"></div>
        </div>
      </div>
      {% endfor %}
    </div>

    <!-- Products Grid -->
    <div id="products-grid" class="hidden grid grid-cols-2 lg:grid-cols-4 gap-4"></div>

    <!-- Error -->
    <div id="products-error" class="hidden text-center py-20">
      <p class="text-red-500 font-semibold mb-3">⚠ Failed to load products</p>
      <button onclick="loadProducts()"
        class="px-6 py-2 bg-green-700 text-white text-sm rounded-full hover:bg-green-800 transition">
        Try Again
      </button>
    </div>

  </div>
</section>

<style>
  .product-img-wrap {
    overflow: hidden;
    position: relative;
  }

  /* Primary image — hover pe scale nahi hogi */
  .product-img-wrap img.img-primary {
    transition: none;
    transform: scale(1);
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Secondary image — pehle hidden, normal size */
  .product-img-wrap img.img-secondary {
    opacity: 0;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transition: opacity 0.3s ease, transform 0.6s ease;
  }

  /* Hover — pehle secondary fadein aaye (scale 1 se start) */
  .product-img-wrap:hover img.img-secondary {
    opacity: 1;
    transform: scale(1.06); /* aate aate scale hogi */
  }

  /* Hover — primary ko kuch nahi karna */
  .product-img-wrap:hover img.img-primary {
    transform: scale(1);
  }
</style>