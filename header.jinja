<style>
  #nav-links::-webkit-scrollbar { display: none; }
</style>

{% include 'components/announcement-bar.jinja' %}

<header class="bg-white border-b border-gray-100 sticky top-0 z-40 w-full">

  <!-- Main Bar -->
  <div class="w-full px-3 md:px-8 flex items-center gap-2 md:gap-4 py-2.5">

    <!-- Hamburger -->
    <button id="mobile-toggle" class="md:hidden text-gray-700 flex-shrink-0 p-1">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <!-- Logo -->
    <a href="/" class="flex-shrink-0 hover:opacity-80 transition-opacity">
      <img src="{{ 'images/safcha logo.png' | asset_url }}" alt="{{ store.name }}" class="h-16 w-auto object-contain brightness-0">
    </a>

    <!-- Search Bar Component -->
    {% include 'components/search-bar.jinja' %}

    <!-- Right Icons -->
    <div class="flex items-center gap-1 md:gap-2 flex-shrink-0">

      <!-- Mobile Search Button -->
      <button class="md:hidden bg-green-700 text-white p-2 rounded-lg">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
      </button>

      <!-- Account -->
      <a href="/account" class="flex items-center gap-1 md:gap-1.5 md:px-4 px-2 py-3 rounded-full md:border border-gray-200 text-base font-medium text-gray-700 hover:bg-gray-50 transition-colors">
        <svg class="w-5 h-5 md:w-5 md:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A8.966 8.966 0 0 1 12 15a8.966 8.966 0 0 1 6.879 2.804M15 11a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
        </svg>
        <span class="hidden md:inline">Account</span>
      </a>

      <!-- Cart -->
      <button id="cart-trigger"
        class="hidden md:flex items-center gap-2 px-4 py-2.5 rounded-full border border-gray-200 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.6 8H19M10 21a1 1 0 1 0 2 0 1 1 0 0 0-2 0zm7 0a1 1 0 1 0 2 0 1 1 0 0 0-2 0z"/>
        </svg>
        <span id="cart-price-desktop">0 SAR</span>
        <span id="cart-badge-desktop" class="text-gray-400 font-normal text-xs">(0)</span>
      </button>

      <!-- Cart Mobile -->
      <button id="cart-trigger-mobile"
        class="md:hidden relative p-2 text-gray-700"
        onclick="openCart()">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.6 8H19M10 21a1 1 0 1 0 2 0 1 1 0 0 0-2 0zm7 0a1 1 0 1 0 2 0 1 1 0 0 0-2 0z"/>
        </svg>
        <span id="cart-badge-mobile"
          class="absolute -top-1 -right-1 bg-green-600 text-white text-[10px] rounded-full w-4 h-4 hidden items-center justify-center font-bold">0</span>
      </button>

    </div>
  </div>

  <!-- Nav Categories Component -->
  {% include 'components/nav-categories.jinja' %}

  <!-- Mobile Drawer Component -->
  {% include 'components/mobile-drawer.jinja' %}

</header>

<!-- Cart Sidebar Component -->
{% include 'components/cart-sidebar.jinja' %}