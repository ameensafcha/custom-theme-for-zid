{# Black Overlay #}
<div id="cart-overlay"
  class="fixed inset-0 bg-black/50 z-[60] opacity-0 pointer-events-none transition-opacity duration-300">
</div>

{# Cart Sidebar Panel #}
<div id="cart-sidebar"
  class="fixed top-0 right-0 h-full bg-white z-[60] flex flex-col shadow-lg w-full md:w-3/5 lg:w-[30%] lg:max-w-lg"
  style="transform:translateX(100%);transition:transform 0.3s ease;">

  {# Header #}
  <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
    <h2 class="text-lg font-bold text-gray-800">Your Cart</h2>
    <button id="cart-close" class="text-gray-400 hover:text-gray-700 transition-colors">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  {# Free Shipping Progress Bar #}
  <div class="px-5 py-3 bg-green-50 border-b border-green-100">
    <div class="flex justify-between text-xs text-green-700 mb-1 font-medium">
      <span>🚚 Free shipping progress</span>
      <span>200 SAR</span>
    </div>
    <div class="w-full bg-green-200 rounded-full h-2">
      <div class="bg-green-600 h-2 rounded-full" style="width: 40%;"></div>
    </div>
  </div>

  {# Cart Items #}
  <div id="cart-items-container" class="flex-1 overflow-y-auto px-5 py-4">
    <div class="flex flex-col items-center justify-center h-full text-center">
      <svg class="w-12 h-12 text-gray-200 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
          d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.6 8H19M10 21a1 1 0 1 0 2 0 1 1 0 0 0-2 0zm7 0a1 1 0 1 0 2 0 1 1 0 0 0-2 0z"/>
      </svg>
      <p class="text-gray-400 text-sm">Loading cart...</p>
    </div>
  </div>

  {# Footer #}
  <div class="px-5 py-4 border-t border-gray-100 bg-white">

    {# Coupon — sirf ek baar #}
    <div class="mb-4">
      <div class="flex gap-2">
        <input
          type="text"
          id="sidebar-coupon-input"
          placeholder="Discount coupon"
          class="flex-1 border border-gray-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-400"
        >
        <button onclick="applySidebarCoupon()"
          class="px-3 py-2 border border-gray-800 text-gray-800 text-xs font-semibold rounded-xl hover:bg-gray-800 hover:text-white transition">
          Apply
        </button>
      </div>
      <p id="sidebar-coupon-msg" class="text-xs mt-1 hidden"></p>
    </div>

    {# Subtotal + Items count #}
    <div class="flex justify-between text-sm text-gray-500 mb-3">
      <span>Subtotal <span id="cart-items-count" class="text-gray-400">(0 items)</span></span>
      <span id="cart-subtotal" class="font-semibold text-gray-800">0 SAR</span>
    </div>

    {# Checkout #}
    <a href="/checkout"
      class="block w-full bg-green-700 hover:bg-green-800 text-white text-center font-bold py-3 rounded-xl transition-colors text-sm mb-2">
      Checkout
    </a>
    <a href="/cart"
      class="block w-full text-center text-green-700 font-medium text-sm hover:underline py-1">
      View Full Cart
    </a>

  </div>

</div>